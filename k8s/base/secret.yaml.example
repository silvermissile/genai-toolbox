# Secret 配置模板
# 重要：不要将实际的 secret.yaml 提交到 Git
# 使用方法：
#   1. 复制此文件: cp secret.yaml.example secret.yaml
#   2. 修改 secret.yaml 中的实际值
#   3. 应用: kubectl apply -f secret.yaml
#   4. 不要提交 secret.yaml 到版本控制

apiVersion: v1
kind: Secret
metadata:
  name: toolbox-secrets
  namespace: mcp-toolbox
type: Opaque
stringData:
  # 数据库连接信息
  POSTGRES_HOST: "your-postgres-host.example.com"
  POSTGRES_DB: "your_database"
  POSTGRES_USER: "your_username"
  POSTGRES_PASSWORD: "your_secure_password"
  
  # 如果使用 Google 认证（可选）
  # GOOGLE_CLIENT_ID: "your-client-id.apps.googleusercontent.com"
  
  # 其他敏感配置
  # API_KEY: "your-api-key"

---
# 用于 BasicAuth 的 Secret（由脚本自动生成，也可手动创建）
