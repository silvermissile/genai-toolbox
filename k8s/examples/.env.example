# MCP Toolbox 客户端环境变量配置示例
# 
# 使用方法:
#   1. 复制此文件: cp .env.example .env
#   2. 修改 .env 中的实际值
#   3. 不要将 .env 提交到版本控制

# Toolbox 服务地址
TOOLBOX_URL=https://toolbox.example.com

# BasicAuth 认证信息
TOOLBOX_USER=admin
TOOLBOX_PASSWORD=your-secure-password

# 可选: 数据库连接信息（如果需要直接连接）
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=mydb
# POSTGRES_USER=user
# POSTGRES_PASSWORD=password
